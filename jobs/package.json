{
  "name": "@seed/jobs",
  "version": "1.0.0",
  "description": "Background job workers (BullMQ + Redis)",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist --dts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@seed/database": "workspace:*",
    "bullmq": "^5.56.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
