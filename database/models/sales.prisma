// -----------------------------------------------------
// SALES FLOW
// SaleInvoice → SalesReturn
// -----------------------------------------------------

model SaleInvoice {
  id             String         @id @default(cuid())
  documentNumber String
  status         DocumentStatus @default(DRAFT)
  paymentStatus  PaymentStatus  @default(UNPAID)
  invoiceDate    DateTime       @default(now())
  dueDate        DateTime?
  notes          String?
  totalAmount    Decimal        @default(0)
  taxAmount      Decimal        @default(0)
  discountAmount Decimal        @default(0)
  grandTotal     Decimal        @default(0)

  // GST amounts (populated at confirmation)
  taxableAmount  Decimal        @default(0)
  cgstAmount     Decimal        @default(0)
  sgstAmount     Decimal        @default(0)
  igstAmount     Decimal        @default(0)
  cessAmount     Decimal        @default(0)

  // Payment tracking
  amountPaid     Decimal        @default(0)
  amountDue      Decimal        @default(0)

  // Shipping / delivery info
  placeOfSupply  String?
  shippingAddress String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customerId String
  customer   Party  @relation("CustomerSaleInvoices", fields: [customerId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  items        SaleInvoiceItem[]
  salesReturns SalesReturn[]
  eInvoice     EInvoice?
  eWayBill     EWayBill?

  @@unique([businessId, documentNumber])
  @@index([businessId, invoiceDate])
  @@index([customerId])
  @@map("sale_invoices")
}

model SaleInvoiceItem {
  id            String  @id @default(cuid())
  quantity      Decimal
  unitPrice     Decimal
  taxRate       Decimal @default(0)
  discount      Decimal @default(0)
  taxableAmount Decimal @default(0)
  cgstRate      Decimal @default(0)
  cgstAmount    Decimal @default(0)
  sgstRate      Decimal @default(0)
  sgstAmount    Decimal @default(0)
  igstRate      Decimal @default(0)
  igstAmount    Decimal @default(0)
  cessAmount    Decimal @default(0)
  totalPrice    Decimal
  costPrice     Decimal // snapshot for COGS calculation
  hsnCode       String?

  saleInvoiceId String
  saleInvoice   SaleInvoice @relation(fields: [saleInvoiceId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  shelfId String?
  shelf   Shelf?  @relation(fields: [shelfId], references: [id])

  batchId String?
  batch   ProductBatch? @relation(fields: [batchId], references: [id])

  @@map("sale_invoice_items")
}

// Sales Returns (triggers SALES_RETURN_IN ledger)
model SalesReturn {
  id             String         @id @default(cuid())
  documentNumber String
  status         DocumentStatus @default(DRAFT)
  returnDate     DateTime       @default(now())
  reason         String?
  notes          String?
  totalAmount    Decimal        @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customerId String
  customer   Party  @relation("CustomerSalesReturns", fields: [customerId], references: [id])

  saleInvoiceId String?
  saleInvoice   SaleInvoice? @relation(fields: [saleInvoiceId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  items SalesReturnItem[]

  @@unique([businessId, documentNumber])
  @@index([businessId, returnDate])
  @@index([customerId])
  @@map("sales_returns")
}

model SalesReturnItem {
  id         String  @id @default(cuid())
  quantity   Decimal
  unitPrice  Decimal
  totalPrice Decimal

  salesReturnId String
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  shelfId String?
  shelf   Shelf?  @relation(fields: [shelfId], references: [id])

  batchId String?
  batch   ProductBatch? @relation(fields: [batchId], references: [id])

  @@map("sales_return_items")
}
