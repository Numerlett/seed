// -----------------------------------------------------
// BUSINESS MANAGEMENT
// -----------------------------------------------------

enum BusinessMembershipType {
  OWNER
  STAFF
}

enum CostingMethod {
  FIFO
  WEIGHTED_AVERAGE
}

model Business {
  id          String  @id @default(cuid())
  name        String
  ownerId     String
  description String?
  email       String?
  phone       String?
  logoImage   String?
  website     String?

  // GST / Tax identity
  gstin       String?
  pan         String?
  stateCode   String? @db.VarChar(2)

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  costingMethod CostingMethod @default(WEIGHTED_AVERAGE)

  owner           User                 @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         BusinessMembership[]
  products        Product[]
  categories      Category[]
  parties         Party[]
  warehouses      Warehouse[]
  inventoryLedger InventoryLedger[]

  // Transaction documents
  purchaseOrders    PurchaseOrder[]
  goodsReceiptNotes GoodsReceiptNote[]
  saleInvoices      SaleInvoice[]
  purchaseReturns   PurchaseReturn[]
  salesReturns      SalesReturn[]
  stockAdjustments  StockAdjustment[]
  stockTransfers    StockTransfer[]
  damageReports     DamageReport[]

  // New modules
  gstRegistration    GSTRegistration?
  chartOfAccounts    ChartOfAccount[]
  fiscalYears        FiscalYear[]
  bankAccounts       BankAccount[]
  payments           Payment[]
  cheques            Cheque[]
  messageTemplates   MessageTemplate[]
  billsOfMaterials   BillOfMaterials[]
  workOrders         WorkOrder[]
  serialNumbers      SerialNumber[]
  leads              Lead[]
  activities         Activity[]
  tasks              Task[]
  costCentres        CostCentre[]

  @@unique([ownerId, name])
  @@map("businesses")
}

model BusinessMembership {
  id         String                 @id @default(cuid())
  userId     String
  businessId String
  title      String?
  role       BusinessMembershipType @default(STAFF)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("business_memberships")
}
