// -----------------------------------------------------
// PARTY MANAGEMENT (Customers & Suppliers)
// -----------------------------------------------------

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

model Party {
  id         String    @id @default(cuid())
  name       String
  email      String?
  phone      String?
  partyType  PartyType
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  addresses Address[]

  // Supplier relations
  purchaseOrders    PurchaseOrder[]    @relation("SupplierPurchaseOrders")
  goodsReceiptNotes GoodsReceiptNote[] @relation("SupplierGRNs")
  purchaseReturns   PurchaseReturn[]   @relation("SupplierPurchaseReturns")

  // Customer relations
  saleInvoices SaleInvoice[] @relation("CustomerSaleInvoices")
  salesReturns SalesReturn[] @relation("CustomerSalesReturns")

  @@index([name])
  @@map("parties")
}

model Address {
  id         String   @id @default(cuid())
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@map("addresses")
}
