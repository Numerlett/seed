// -----------------------------------------------------
// INVENTORY LEDGER & STOCK SUMMARY (Core Engine)
// -----------------------------------------------------

enum InventoryTransactionType {
  PURCHASE_IN
  SALE_OUT
  SALES_RETURN_IN
  PURCHASE_RETURN_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE_OUT
  EXPIRED_OUT
}

enum DocumentStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Core engine: every stock movement creates one ledger entry
model InventoryLedger {
  id              String                   @id @default(cuid())
  transactionType InventoryTransactionType
  referenceTable  String? // e.g. "purchase_orders", "sale_invoices"
  referenceId     String? // FK to the source document
  quantityIn      Decimal                  @default(0)
  quantityOut     Decimal                  @default(0)
  unitCost        Decimal
  totalCost       Decimal
  transactionDate DateTime                 @default(now())
  notes           String?
  createdAt       DateTime                 @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  shelfId String?
  shelf   Shelf?  @relation(fields: [shelfId], references: [id])

  batchId String?
  batch   ProductBatch? @relation(fields: [batchId], references: [id])

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([productId, transactionDate])
  @@index([businessId, transactionDate])
  @@index([referenceTable, referenceId])
  @@map("inventory_ledger")
}

// Auto-calculated stock summary; never manually edited
model InventoryStock {
  id              String   @id @default(cuid())
  currentQuantity Decimal  @default(0)
  currentValue    Decimal  @default(0)
  updatedAt       DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  shelfId String?
  shelf   Shelf?  @relation(fields: [shelfId], references: [id])

  batchId String?
  batch   ProductBatch? @relation(fields: [batchId], references: [id])

  @@unique([productId, warehouseId, shelfId, batchId])
  @@map("inventory_stock")
}
