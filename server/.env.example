# Server Configuration
PORT=8080
NODE_ENV=development # or production

# Deployment mode
# - long-running: full-featured. Requires REDIS_URL. Background workers in @seed/jobs
#   process queued work (email, sms, pdf, einvoice, recurring invoices, alerts, etc.).
# - serverless: no Redis, no workers. Queueable work runs inline; scheduled/heavy
#   features (recurring invoices, stock alerts, payment reminders, large reports)
#   reject with NOT_IMPLEMENTED via longRunningOnlyProcedure.
DEPLOYMENT_MODE=long-running

# Auth Secrets (Generate strong random secrets for production!)
REFRESH_TOKEN_SECRET=your-refresh-token-secret
ACCESS_TOKEN_SECRET=your-access-token-secret

# Token Expiry (Optional - defaults shown)
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Database
DATABASE_URL=postgresql://postgres:1234567890@localhost:5432/seed

# Test Database (separate from dev DB — used only when running tests)
TEST_DATABASE_URL=postgresql://postgres:1234567890@localhost:5432/seed_test

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (Gmail)
SMTP_USERNAME=xxxxx
SMTP_PASSWORD=xxxxx
SMTP_PORT=587
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_MAIL=example@gmail.com

# Optional Test Configuration
TEST_MAIL=test@example.com
TEST_OTP=123456

# AWS Credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# Redis (required by @seed/jobs for BullMQ queues)
# Required only when DEPLOYMENT_MODE=long-running. Omit in serverless mode.
# Local dev: docker run -d --name redis-seed -p 6379:6379 redis:7-alpine
# Production: Upstash, Redis Cloud, or AWS ElastiCache
REDIS_URL=redis://localhost:6379
