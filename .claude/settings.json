{
  "permissions": {
    "allow": [
      "Bash(pnpm add *)",
      "Bash(pnpm --filter web build)",
      "Bash(pnpm --filter @seed/database build)",
      "Bash(git mv *)",
      "Bash(rmdir jobs/src)",
      "Bash(mkdir -p pdf/templates)",
      "Bash(rmdir pdf/src/templates pdf/src)",
      "Bash(mkdir -p jobs/lib)",
      "Bash(mkdir -p integrations/adapters)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status --json",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph detect-changes --brief",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
