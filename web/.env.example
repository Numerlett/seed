NEXT_PUBLIC_SERVER_BASE_URL=http://localhost:8080

# Must match ACCESS_TOKEN_SECRET in server/.env — used by Next.js middleware to verify JWTs
ACCESS_TOKEN_SECRET=your-access-token-secret

# Required by next.config.ts to allowlist S3 image domains
NEXT_PUBLIC_AWS_S3_BUCKET_NAME=your-s3-bucket-name
NEXT_PUBLIC_AWS_REGION=ap-south-1